# ==========================
# PostgreSQL Configuration
# ==========================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
DB_TABLE=your_table_name
DB_USER=your_username
DB_PASSWORD=your_password

# SQLAlchemy Connection URL
POSTGRES_DB_URL=postgresql+psycopg2://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ==========================
# Google Sheets Configuration
# ==========================
GSHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SPREADSHEET_ID/edit
GSHEET_SHEET_NAME=Sheet1
GSHEET_SERVICE_ACCOUNT_PATH=google-sheets-api.json